# =====================================================
# Delivery Shop v2 - Конфигурация окружения
# =====================================================

# Настройки приложения
APP_ENV=local
APP_DEBUG=true

# База данных MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=delivery_shop
DB_USER=root
DB_PASS=

# Сессия
SESSION_LIFETIME=7200

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# WhatsApp уведомления (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=