# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true

# 4 space indentation
[*.php]
indent_style = space
indent_size = 4

# 2 space indentation
[*.js]
indent_style = space
indent_size = 2

# 2 space indentation
[*.css]
indent_style = space
indent_size = 2

# 2 space indentation
[*.html]
indent_style = space
indent_size = 2

# 2 space indentation
[*.json]
indent_style = space
indent_size = 2

# 2 space indentation
[*.md]
indent_style = space
indent_size = 2

# 4 space indentation for YAML files
[*.yml]
indent_style = space
indent_size = 2

# 4 space indentation for YAML files
[*.yaml]
indent_style = space
indent_size = 2

# Trim trailing whitespace
[*.php]
trim_trailing_whitespace = true

[*.js]
trim_trailing_whitespace = true

[*.css]
trim_trailing_whitespace = true

[*.html]
trim_trailing_whitespace = true

[*.json]
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = true

[*.yml]
trim_trailing_whitespace = true

[*.yaml]
trim_trailing_whitespace = true