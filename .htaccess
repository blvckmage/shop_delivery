RewriteEngine On
RewriteBase /

# Разрешаем доступ к статическим файлам в uploads
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^uploads/(.*)$ - [L]

# Если запрашивается существующий файл или папка - не перенаправляем
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Все остальные запросы идут на index.php
RewriteRule ^(.*)$ index.php [QSA,L]
