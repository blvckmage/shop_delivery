RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# PWA Headers
<FilesMatch "\.(manifest|appcache|html?|xml|json)$">
    FileETag None
    <ifModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </ifModule>
</FilesMatch>

# Service Worker - должен всегда возвращаться свежим
<FilesMatch "sw\.js$">
    FileETag None
    <ifModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </ifModule>
</FilesMatch>

# manifest.json
<FilesMatch "manifest\.json$">
    <ifModule mod_headers.c>
        Header set Content-Type "application/manifest+json"
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
    </ifModule>
</FilesMatch>

# Иконки и изображения - кэшируем на месяц
<FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|svg|js|css|swf|woff|woff2)$">
    <ifModule mod_headers.c>
        Header set Cache-Control "max-age=2592000, public"
    </ifModule>
</FilesMatch>

# Включаем gzip сжатие
<ifModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/manifest+json
</ifModule>